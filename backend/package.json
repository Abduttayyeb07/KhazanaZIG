{
  "name": "@zig/core-engine",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "chaos": "tsx src/chaos/harness.ts",
    "test:risk": "tsx src/decision-gate/risk-engine.test.ts",
