# ─── Exchange Keys ────────────────────────────────────────────────────────────
# Exchange keys are NOT stored here.
# They are user-owned session credentials entered via the frontend.
# They are encrypted by CredentialVault, held only in TradingSession RAM,
# and destroyed on session end. They never touch config or logs.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL= db url

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALLOWED_USER_IDS=

# ─── System ───────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
OPERATIONAL_MODE=READ_ONLY

# Master encryption key — encrypts user exchange credentials at rest (AES-256-GCM).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 64 hex chars. If left empty, an ephemeral key is generated each boot (dev only).
ENCRYPTION_KEY=

# ─── Control-plane security ───────────────────────────────────────────────────
# API bind host. 0.0.0.0 = reachable from network. Use 127.0.0.1 behind a proxy.
API_HOST=0.0.0.0
API_PORT=3001

# Operator token — required for all control routes (/api/operator/*).
# EMPTY = control routes are disabled (fail closed). Set in production.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPERATOR_TOKEN=

# Dashboard origin allowed by CORS. Set to your real dashboard URL in production.
DASHBOARD_ORIGIN=http://localhost:3000

# ─── Treasury Config ──────────────────────────────────────────────────────────
TRADING_SYMBOL=ZIGUSDT
BASE_ASSET=ZIG
QUOTE_ASSET=USDT
# Protected reserve floor (in base asset). Holdings above this are harvestable;
# the floor is never sold into. 0 = treat the whole balance as active.
RESERVE_FLOOR=0

# -----------------------------
# Phase 5 Risk / Sizing Params
# -----------------------------
MAX_ORDER_ACTIVE_PCT=0.05
MAX_DAILY_SELL_ACTIVE_PCT=0.15
MAX_DAILY_BUY_USDT_PCT=0.25

LIQUIDITY_PARTICIPATION_PCT=0.10

DEFENSIVE_SIZE_MULTIPLIER=0.35
HIGH_VOL_SIZE_MULTIPLIER=0.40
CHAOTIC_SIZE_MULTIPLIER=0

MIN_ORDER_ZIG=100
MAX_OPEN_ORDERS_PER_EXCHANGE=5

MIN_SELL_PROFIT_BPS=300
MIN_REBUY_DISTANCE_BPS=300

MAX_SPREAD_BPS=150
CHAOTIC_SPREAD_MULTIPLIER=3

MAX_15M_MOVE_PCT=0.08
LOW_VOL_ATR_PCT=0.01
NORMAL_VOL_ATR_PCT=0.03
HIGH_VOL_ATR_PCT=0.07

MAX_RECONNECTS_PER_5M=5
RECONCILIATION_REQUIRED_STATUS=MATCH

# ── Paper soak (live-market forward test) ────────────────────────────────────
# Real market data + virtual money + real Phase 5 rules. Headless, reports to
# Telegram only. SAFETY: the auto harvest-driver runs ONLY when
# OPERATIONAL_MODE=PAPER_MODE — it is hard-disabled in NORMAL/DEFENSIVE.
# To run a soak: set OPERATIONAL_MODE=PAPER_MODE and PAPER_SOAK_ENABLED=true.
# NOTE: no inline (# ...) comments after a value below — Docker's env_file passes
# them through verbatim (NaN). Keep comments on their own lines.
PAPER_SOAK_ENABLED=false
SOAK_EXCHANGE=bybit
# virtual total ZIG (with RESERVE_FLOOR=5000000 → 1,000,000 active)
SOAK_VIRTUAL_ZIG=6000000
# virtual USDT for rebuys
SOAK_VIRTUAL_USDT=15000
# cost basis of opening ZIG; 0 = use market mid at boot
SOAK_ENTRY_COST=0
# how often the harvest driver evaluates (seconds)
SOAK_TICK_SECONDS=30
# fraction of USDT per rebuy intent
SOAK_BUY_SLICE_PCT=0.2

# ── Paper soak v2 — discipline, cycles, realism ──────────────────────────────
# Cooldowns + buckets stop machine-gun trading in the same price zone (seconds / bps).
SELL_COOLDOWN_SECONDS=120
BUY_COOLDOWN_SECONDS=120
SELL_BUCKET_BPS=25
BUY_BUCKET_BPS=25
REJECT_BACKOFF_SECONDS=300
# Pause new sells once this fraction of starting active inventory is sold-but-not-rebought.
MAX_ACTIVE_DEPLOYED_PCT=0.25
MAX_UNRECOVERED_ACTIVE_PCT=0.25
# Paper fill realism (fee + slippage in bps, probabilistic fill).
PAPER_TAKER_FEE_BPS=10
PAPER_SLIPPAGE_BPS=5
PAPER_FILL_PROBABILITY=0.75
# Telegram summary cadence (seconds) — summaries instead of per-fill spam.
TG_FILL_SUMMARY_INTERVAL_SECONDS=900
TG_REJECT_SUMMARY_INTERVAL_SECONDS=900
